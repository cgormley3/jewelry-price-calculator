# Optional BOMA / deployment URLs (see lib/branding.ts)
# Default org site is https://www.bouldermetalsmiths.com/ — set to override:
# NEXT_PUBLIC_ORG_SITE_URL=https://example.org
# NEXT_PUBLIC_PRIVACY_POLICY_URL=https://example.org/privacy

# Production canonical app URL (required for Shopify OAuth + consistent auth redirects).
# After DNS + Vercel: use your vault subdomain, e.g.:
# NEXT_PUBLIC_APP_URL=https://vault.bouldermetalsmiths.com
# NEXT_PUBLIC_APP_URL=http://localhost:3000
